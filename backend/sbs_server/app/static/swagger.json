{
    "openapi": "3.0.0",
    "info": {
        "title": "Biological Data Processing API",
        "description": "API for managing SBOL data, file processing, and assembly planning",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "Main API endpoint"
        }
    ],
    "tags": [
        {
            "name": "System",
            "description": "System health and data endpoints"
        },
        {
            "name": "File Upload",
            "description": "File upload and processing endpoints"
        },
        {
            "name": "Assembly",
            "description": "Biological assembly operations"
        },
        {
            "name": "Data Processing",
            "description": "Data extraction and processing"
        },
        {
            "name": "BuildCompiler",
            "description": "Versioned planning, approval, compilation, and artifact APIs"
        }
    ],
    "paths": {
        "/buildcompiler/capabilities": {
            "get": {
                "tags": ["BuildCompiler"],
                "summary": "Get the installed BuildCompiler contract",
                "description": "Returns the pinned BuildCompiler version, stages, protocol modes, defaults, bounds, and optional automation availability.",
                "responses": {
                    "200": {
                        "description": "Versioned BuildCompiler capabilities",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": ["schema_version", "buildcompiler", "stages", "defaults", "bounds"],
                                    "properties": {
                                        "schema_version": {"type": "string", "example": "1.0"},
                                        "buildcompiler": {"type": "object"},
                                        "stages": {"type": "array", "items": {"type": "string"}},
                                        "protocol_modes": {"type": "array", "items": {"type": "string"}},
                                        "defaults": {"type": "object"},
                                        "bounds": {"type": "object"},
                                        "availability": {"type": "object"}
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/buildcompiler/plan": {
            "post": {
                "tags": ["BuildCompiler"],
                "summary": "Create a deterministic BuildCompiler plan",
                "description": "Plans a local SBOL document or a token-authenticated SynBioHub design. Tokens are accepted only in the dedicated request header and are never persisted.",
                "security": [{}, {"SynBioHubToken": []}],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {"$ref": "#/components/schemas/BuildRequestEnvelope"}
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Versioned plan and deterministic plan ID",
                        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BuildPlanResponse"}}}
                    },
                    "400": {"description": "Invalid request or options", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "401": {"description": "SynBioHub credential missing or rejected", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "413": {"description": "SBOL input exceeds the configured limit", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "422": {"description": "Invalid SBOL input", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "502": {"description": "SynBioHub network or response failure", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "504": {"description": "Configured synchronous runtime limit exceeded", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}}
                }
            }
        },
        "/buildcompiler/compile": {
            "post": {
                "tags": ["BuildCompiler"],
                "summary": "Verify and compile an approved BuildCompiler plan",
                "description": "Replans the original request, rejects changed plans, applies run-scoped approvals, executes BuildCompiler, and returns an integrity-checked ZIP artifact.",
                "security": [{}, {"SynBioHubToken": []}],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {"$ref": "#/components/schemas/BuildCompileRequest"}
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Build result DTO and Base64 ZIP artifact",
                        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BuildCompileResponse"}}}
                    },
                    "400": {"description": "Invalid plan DTO or approvals", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "409": {"description": "Blocked, stale, or changed plan", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "413": {"description": "Generated artifact exceeds the configured limit", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "422": {"description": "BuildCompiler execution failure", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}},
                    "504": {"description": "Configured synchronous runtime limit exceeded", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/APIError"}}}}
                }
            }
        },
        "/status": {
            "get": {
                "tags": ["System"],
                "summary": "Check if the API is running",
                "description": "Simple endpoint to verify the API is operational",
                "responses": {
                    "200": {
                        "description": "API is operational",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "working"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/data": {
            "get": {
                "tags": ["System"],
                "summary": "Get data JSON",
                "description": "Returns the data.json static file",
                "responses": {
                    "200": {
                        "description": "Data returned successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/test_metadata_upload": {
            "post": {
                "tags": ["File Upload"],
                "summary": "Test metadata file upload",
                "description": "Endpoint for testing metadata file uploads",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "file": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "Metadata file to upload"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Upload successful"
                    },
                    "400": {
                        "description": "Bad request"
                    }
                }
            }
        },
        "/upload_sbs": {
            "post": {
                "tags": ["File Upload"],
                "summary": "Upload file from SBS",
                "description": "Uploads a metadata file with parameters from SBS, processes it with Tricahue XDC, and uploads to SBH",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "Metadata": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "Metadata file to upload"
                                    },
                                    "Params": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "Parameters file in JSON format"
                                    }
                                },
                                "required": ["Metadata", "Params"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Upload successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "sbh_url": {
                                            "type": "string",
                                            "description": "SBH URL where the data was uploaded"
                                        },
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request"
                    }
                }
            }
        },
        "/extract_data": {
            "post": {
                "tags": ["Data Processing"],
                "summary": "Extract data from files",
                "description": "Processes metadata and platereader output files to extract data",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "Metadata": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "Metadata file"
                                    },
                                    "platereader_output": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "Platereader output file"
                                    },
                                    "preset": {
                                        "type": "string",
                                        "description": "Selected preset for processing"
                                    }
                                },
                                "required": ["Metadata", "platereader_output", "preset"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Data extraction successful",
                        "content": {
                            "application/octet-stream": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request"
                    }
                }
            }
        },
        "/return_info": {
            "post": {
                "tags": ["System"],
                "summary": "Return user information",
                "description": "Returns the profile information of the logged in user",
                "responses": {
                    "200": {
                        "description": "Information returned successfully"
                    }
                }
            }
        },
        "/sbol_2_build_golden_gate": {
            "post": {
                "tags": ["Assembly"],
                "summary": "Build Golden Gate assembly",
                "description": "Creates a SBOL2 golden gate assembly plan based on input parts and backbone",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "plasmid_backbone": {
                                        "type": "string",
                                        "format": "binary",
                                        "description": "Plasmid backbone file"
                                    },
                                    "insert_parts": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "format": "binary"
                                        },
                                        "description": "Insert parts files"
                                    },
                                    "wizard_selections": {
                                        "type": "string",
                                        "description": "JSON string containing wizard selections including assembly method and restriction enzyme"
                                    }
                                },
                                "required": ["plasmid_backbone", "insert_parts", "wizard_selections"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Assembly plan created successfully",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "error": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "SynBioHubToken": {
                "type": "apiKey",
                "in": "header",
                "name": "X-SynBioHub-Token",
                "description": "Request-scoped SynBioHub token; never included in request JSON or stored by the backend."
            }
        },
        "schemas": {
            "BuildRequestEnvelope": {
                "type": "object",
                "required": ["design"],
                "properties": {
                    "design": {
                        "type": "object",
                        "required": ["source"],
                        "properties": {
                            "source": {"type": "string", "enum": ["local", "project", "synbiohub"]},
                            "content": {"type": "string", "description": "SBOL 2 XML for local/project sources."},
                            "identity": {"type": "string"},
                            "uri": {"type": "string"},
                            "registry": {"type": "string"}
                        }
                    },
                    "inventory": {
                        "type": "object",
                        "properties": {
                            "registry": {"type": "string"},
                            "collections": {"type": "array", "items": {"oneOf": [{"type": "string"}, {"type": "object"}]}}
                        }
                    },
                    "options": {"type": "object"}
                }
            },
            "BuildPlanDTO": {
                "type": "object",
                "required": ["schema_version", "kind", "lvl2_requests", "lvl1_requests", "domestication_requests", "unsupported", "warnings"],
                "properties": {
                    "schema_version": {"type": "string", "example": "1.0"},
                    "kind": {"type": "string", "enum": ["build_plan"]},
                    "lvl2_requests": {"type": "array", "items": {"type": "object"}},
                    "lvl1_requests": {"type": "array", "items": {"type": "object"}},
                    "domestication_requests": {"type": "array", "items": {"type": "object"}},
                    "unsupported": {"type": "array", "items": {"type": "object"}},
                    "warnings": {"type": "array", "items": {"type": "object"}}
                }
            },
            "BuildPlanResponse": {
                "type": "object",
                "required": ["schema_version", "plan_id", "status", "plan", "summary", "required_approvals"],
                "properties": {
                    "schema_version": {"type": "string", "example": "1.0"},
                    "plan_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                    "status": {"type": "string", "enum": ["ready", "blocked"]},
                    "plan": {"$ref": "#/components/schemas/BuildPlanDTO"},
                    "summary": {"type": "object"},
                    "required_approvals": {"type": "array", "items": {"type": "object"}}
                }
            },
            "BuildCompileRequest": {
                "type": "object",
                "required": ["plan_id", "plan", "request", "approvals"],
                "properties": {
                    "plan_id": {"type": "string"},
                    "plan": {"$ref": "#/components/schemas/BuildPlanDTO"},
                    "request": {"$ref": "#/components/schemas/BuildRequestEnvelope"},
                    "approvals": {"type": "array", "items": {"type": "string"}}
                }
            },
            "BuildCompileResponse": {
                "type": "object",
                "required": ["schema_version", "plan_id", "status", "result", "artifact"],
                "properties": {
                    "schema_version": {"type": "string"},
                    "plan_id": {"type": "string"},
                    "status": {"type": "string"},
                    "result": {"type": "object"},
                    "artifact": {
                        "type": "object",
                        "required": ["filename", "media_type", "encoding", "size_bytes", "sha256", "contents", "data"],
                        "properties": {
                            "filename": {"type": "string"},
                            "media_type": {"type": "string", "enum": ["application/zip"]},
                            "encoding": {"type": "string", "enum": ["base64"]},
                            "size_bytes": {"type": "integer"},
                            "sha256": {"type": "string"},
                            "contents": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "required": ["filename", "type", "stage", "media_type", "description", "validation_status"],
                                    "properties": {
                                        "filename": {"type": "string"},
                                        "type": {"type": "string"},
                                        "stage": {"type": "string"},
                                        "media_type": {"type": "string"},
                                        "description": {"type": "string"},
                                        "validation_status": {"type": "string"}
                                    }
                                }
                            },
                            "data": {"type": "string", "format": "byte"}
                        }
                    }
                }
            },
            "APIError": {
                "type": "object",
                "required": ["schema_version", "error"],
                "properties": {
                    "schema_version": {"type": "string"},
                    "error": {
                        "type": "object",
                        "required": ["code", "message"],
                        "properties": {
                            "code": {"type": "string"},
                            "message": {"type": "string"},
                            "correlation_id": {"type": "string", "format": "uuid"},
                            "details": {"type": "object"}
                        }
                    }
                }
            },
            "XDCParams": {
                "type": "object",
                "properties": {
                    "fj_url": {
                        "type": "string",
                        "description": "FreeGenes URL"
                    },
                    "sbh_url": {
                        "type": "string",
                        "description": "SynBioHub URL"
                    },
                    "sbh_collec": {
                        "type": "string",
                        "description": "SynBioHub collection"
                    },
                    "sbh_collec_desc": {
                        "type": "string",
                        "description": "SynBioHub collection description"
                    },
                    "sbh_overwrite": {
                        "type": "boolean",
                        "description": "Overwrite existing SynBioHub data"
                    },
                    "fj_overwrite": {
                        "type": "boolean",
                        "description": "Overwrite existing FreeGenes data"
                    },
                    "fj_token": {
                        "type": "string",
                        "description": "FreeGenes authentication token"
                    },
                    "sbh_token": {
                        "type": "string",
                        "description": "SynBioHub authentication token"
                    }
                }
            },
            "WizardSelections": {
                "type": "object",
                "properties": {
                    "formValues": {
                        "type": "object",
                        "properties": {
                            "assemblyMethod": {
                                "type": "string",
                                "enum": ["MoClo"],
                                "description": "Assembly method"
                            },
                            "restrictionEnzyme": {
                                "type": "string",
                                "description": "Restriction enzyme for the assembly"
                            }
                        }
                    }
                }
            }
        }
    }
}
