{
  "openapi": "3.0.3",
  "info": {
    "title": "SynBioSuite API",
    "description": "OpenAPI documentation for the SynBioSuite Flask backend.",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Relative to current host (works for local, container, and deployed environments)"
    }
  ],
  "tags": [
    {
      "name": "System",
      "description": "Service status and debugging helpers"
    },
    {
      "name": "Upload",
      "description": "Metadata upload endpoints"
    },
    {
      "name": "Assembly",
      "description": "Assembly/build operations"
    }
  ],
  "paths": {
    "/api/status": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "description": "Returns a simple status payload if the API is running.",
        "responses": {
          "200": {
            "description": "Service is available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/uploadResource": {
      "post": {
        "tags": ["Upload"],
        "summary": "Upload metadata and publish to SBH/FJ",
        "description": "Processes metadata using XDC and uploads generated content to SynBioHub/Flapjack.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadResourceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/uploadExperiment": {
      "post": {
        "tags": ["Upload"],
        "summary": "Upload experiment package",
        "description": "Alias of uploadResource with the same contract and behavior.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadResourceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/uploadAssembly": {
      "post": {
        "tags": ["Upload"],
        "summary": "Upload assembly data",
        "description": "Placeholder endpoint. Currently not implemented.",
        "responses": {
          "501": {
            "description": "Not implemented",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Not implemented yet"
                }
              }
            }
          }
        }
      }
    },
    "/api/uploadTransformation": {
      "post": {
        "tags": ["Upload"],
        "summary": "Upload transformation data",
        "description": "Placeholder endpoint. Currently not implemented.",
        "responses": {
          "501": {
            "description": "Not implemented",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Not implemented yet"
                }
              }
            }
          }
        }
      }
    },
    "/sbol_2_build_golden_gate": {
      "post": {
        "tags": ["Assembly"],
        "summary": "Generate Golden Gate build plan",
        "description": "Accepts plasmid backbone + insert parts and validates wizard selections.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/GoldenGateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assembly plan generated"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error"
          }
        }
      }
    },
    "/api/build_pudu": {
      "post": {
        "tags": ["Assembly"],
        "summary": "Run PUDU build pipeline",
        "description": "Validates request payload, then runs build script. Currently returns 501 while build output flow is being finalized.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/PuduBuildRequest"
              }
            }
          }
        },
        "responses": {
          "501": {
            "description": "Not implemented",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "PUDU build not implemented yet"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error"
          }
        }
      }
    },
    "/api/inspect_request": {
      "post": {
        "tags": ["System"],
        "summary": "Inspect uploaded JSON files",
        "description": "Debug endpoint that parses each uploaded file as JSON and echoes it back.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Files parsed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "files": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "One or more uploaded files were not valid JSON",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "working"
          }
        },
        "required": ["status"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": ["error"]
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "sbh_url": {
            "type": "string",
            "description": "SynBioHub URL returned by the upload process"
          },
          "status": {
            "type": "string",
            "example": "success"
          }
        },
        "required": ["sbh_url", "status"]
      },
      "UploadResourceRequest": {
        "type": "object",
        "properties": {
          "Metadata": {
            "type": "string",
            "format": "binary",
            "description": "Excel metadata workbook (.xlsx/.xlsm)"
          },
          "Params": {
            "type": "string",
            "format": "binary",
            "description": "JSON file containing XDC configuration and credentials"
          },
          "Attachments": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "binary"
            },
            "description": "Optional attachments to upload to SynBioHub"
          }
        },
        "required": ["Metadata", "Params"]
      },
      "GoldenGateRequest": {
        "type": "object",
        "properties": {
          "plasmid_backbone": {
            "type": "string",
            "format": "binary"
          },
          "insert_parts": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "binary"
            }
          },
          "wizard_selections": {
            "type": "string",
            "description": "JSON string; expected formValues.assemblyMethod=MoClo"
          }
        },
        "required": ["plasmid_backbone", "insert_parts", "wizard_selections"]
      },
      "PuduBuildRequest": {
        "type": "object",
        "properties": {
          "assembly_plan": {
            "type": "string",
            "format": "binary"
          },
          "wizard_selections": {
            "type": "string",
            "description": "JSON string; expected formValues.buildMethod=PUDU"
          }
        },
        "required": ["assembly_plan", "wizard_selections"]
      }
    }
  }
}
